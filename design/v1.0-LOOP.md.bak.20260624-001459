## 五、Agent 可移植层设计（换 LLM 的关键）

### 5.1 LLM 抽象接口

```python
# agents/llm.py
from abc import ABC, abstractmethod

class LLMProvider(ABC):
    """LLM 抽象层。换 Agent 只需实现此接口。"""

    @abstractmethod
    def create_message(
        self,
        model: str,
        system: str,
        messages: list[dict],
        tools: list[dict],
        max_tokens: int = 4096,
    ) -> LLMResponse:
        ...

@dataclass
class LLMResponse:
    stop_reason: str          # "tool_use" | "end_turn" | "stop"
    text: str                 # 文本输出
    tool_calls: list[ToolCall]  # 工具调用列表

@dataclass
class ToolCall:
    id: str
    name: str
    input: dict
```

### 5.2 当前实现 + 未来扩展

```python
# agents/llm.py

class AnthropicProvider(LLMProvider):
    """Claude API 实现。"""
    def __init__(self, api_key: str):
        self.client = anthropic.Anthropic(api_key=api_key)

    def create_message(self, model, system, messages, tools, max_tokens=4096):
        response = self.client.messages.create(
            model=model,
            system=system,
            messages=messages,
            tools=self._format_tools(tools),
            max_tokens=max_tokens,
        )
        return self._parse_response(response)


class OpenAIProvider(LLMProvider):
    """OpenAI API 实现——未来切换。只需实现此接口。"""
    def __init__(self, api_key: str):
        self.client = openai.OpenAI(api_key=api_key)

    def create_message(self, model, system, messages, tools, max_tokens=4096):
        response = self.client.chat.completions.create(
            model=model,
            messages=[{"role": "system", "content": system}] + messages,
            tools=self._format_tools(tools),
            max_tokens=max_tokens,
        )
        return self._parse_response(response)


class LocalProvider(LLMProvider):
    """本地开源模型（Ollama/vLLM）实现——未来切换。"""
    def __init__(self, endpoint: str):
        self.endpoint = endpoint

    def create_message(self, model, system, messages, tools, max_tokens=4096):
        response = requests.post(
            f"{self.endpoint}/v1/chat/completions",
            json={"model": model, "messages": [...], "tools": tools},
        )
        return self._parse_response(response)
```

**换 Agent 的影响范围**：只需实现一个 `LLMProvider` 子类（~100 行），其他所有代码不变。

