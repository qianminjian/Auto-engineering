## 三、Agent 设计

### 3.1 BaseAgent（参考 AutoGen Agent + CrewAI Agent）

```python
# agents/base.py
class BaseAgent:
    """Agent 基类。参考 AutoGen _agent.py + CrewAI agent.py。"""

    id: AgentId
    role: str
    system_prompt: str            # 角色 prompt
    tools: list[BaseTool]        # 可用工具
    llm_client: Anthropic        # Claude API 客户端

    def execute(self, task: Task, context: TaskContext) -> TaskResult:
        """执行任务。内部 while True: LLM调用 → 工具执行 → 观察结果。"""
        messages = [
            {"role": "system", "content": self.system_prompt},
            {"role": "user", "content": self._build_task_prompt(task, context)},
        ]

        while True:
            response = self.llm_client.messages.create(
                model="claude-sonnet-4-6",
                max_tokens=4096,
                tools=self._get_tool_schemas(),
                messages=messages,
            )

            if response.stop_reason != "tool_use":
                break

            for tool_call in response.content:
                if tool_call.type == "tool_use":
                    result = self._execute_tool(tool_call)
                    messages.append({
                        "role": "user",
                        "content": [{
                            "type": "tool_result",
                            "tool_use_id": tool_call.id,
                            "content": str(result),
                        }]
                    })

        return TaskResult(
            agent_id=self.id,
            output=response.content[0].text,
            tool_calls=self._tool_call_log,
        )
```

### 3.2 三个 Agent 具体配置

```python
# agents/architect.py
ArchitectAgent(BaseAgent):
    role = "architect"
    system_prompt = "你是技术架构师。分析需求，输出实现计划..."
    tools = [ReadFileTool(), SearchCodeTool(), ListDirTool()]
    output_schema = ArchitectOutput  # plan, batch_plan, file_list, contracts

# agents/developer.py
DeveloperAgent(BaseAgent):
    role = "developer"
    system_prompt = "你是软件开发者。按 TDD 三步循环实现..."
    tools = [ReadFileTool(), WriteFileTool(), EditFileTool(), RunBashTool(), GitCommitTool()]
    output_schema = DeveloperOutput  # files_changed, test_results, commit_hash

# agents/critic.py
CriticAgent(BaseAgent):
    role = "critic"
    system_prompt = "你是代码审查者。只读，不给实现方案..."
    tools = [ReadFileTool(), GitDiffTool(), RunTestTool()]
    output_schema = CriticOutput  # verdict: APPROVE|MAJOR, findings: [...]
```

