{
  "name": "auto-engineering",
  "version": "5.6.0",
  "description": "Auto-Engineering v5.6 — Tick-Based Discrete Invocation loop with 5-layer verification, PrismScan V5.1 codebase reverse engineering, Gate quality system, and Init-Loop contract.",
  "author": {
    "name": "Qian Minjian (钱敏健)",
    "email": "noreply@anthropic.com"
  },
  "license": "MIT",
  "repository": "https://github.com/qianminjian/Auto-engineering",
  "homepage": "https://github.com/qianminjian/Auto-engineering",
  "keywords": [
    "multi-agent",
    "ai-engineering",
    "dev-loop",
    "guardrails",
    "gate-quality",
    "claude-code-plugin"
  ],
  "commands": "./commands/",
  "hooks": {
    "SessionStart": ["hooks/session-start.sh"],
    "PostToolUse": ["hooks/post-edit.sh"],
    "PreToolUse": ["hooks/pre-tool.sh"],
    "Stop": ["hooks/stop.sh"],
    "onPR": ["hooks/on-pr.sh"]
  },
  "skills": "./skills/",
  "metadata": {
    "min_claude_code_version": "1.0.0",
    "requirements": {
      "python": ">=3.12",
      "uv": ">=0.5.0",
      "git": ">=2.30",
      "sqlite3": ">=3.35"
    },
    "env": {
      "AE_CHECKPOINT_DIR": {
        "description": "Checkpoint SQLite database directory (default: .ae-state)",
        "required": false,
        "default": ".ae-state"
      },
      "AE_DB_PATH": {
        "description": "DEPRECATED: 使用 AE_CHECKPOINT_DIR 替代. Checkpoint DB 路径 (default: .ae-state/checkpoints.db)",
        "required": false,
        "default": ".ae-state/checkpoints.db"
      },
      "AE_LOG_LEVEL": {
        "description": "Logging level: DEBUG/INFO/WARNING/ERROR (default: INFO)",
        "required": false,
        "default": "INFO"
      },
      "AE_GATE_TIMEOUT": {
        "description": "Gate execution timeout in seconds (default: 300, affects safety/lint/type_check/test/build)",
        "required": false,
        "default": "300"
      },
      "AE_MAX_STEPS": {
        "description": "Maximum orchestration loop steps (default: 50)",
        "required": false,
        "default": "50"
      },
      "AE_MAX_TOOL_CALLS": {
        "description": "Maximum tool calls per agent invocation (default: 10)",
        "required": false,
        "default": "10"
      },
      "AE_RETRY_MAX_ATTEMPTS": {
        "description": "Maximum LLM retry attempts on failure (default: 3)",
        "required": false,
        "default": "3"
      },
      "AE_RETRY_TIMEOUT": {
        "description": "LLM retry timeout in seconds (default: 120.0)",
        "required": false,
        "default": "120.0"
      }
    }
  }
}